# App queries — use Supabase transaction-mode pooler (port 6543) on Vercel
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-region.pooler.supabase.com:6543/postgres

# Drizzle migrations only — direct connection bypasses PgBouncer DDL limits
# Leave unset in local dev (DATABASE_URL already points to Docker, which handles DDL fine)
DIRECT_DATABASE_URL=postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres
